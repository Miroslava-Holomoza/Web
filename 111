<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Кава</title>
  <style>
    :root {
      --bg: #f7efe7;
      --bg-soft: #fff8f2;
      --brown: #4d2f24;
      --brown-2: #6b4434;
      --accent: #c48a5a;
      --accent-2: #e7b88e;
      --text: #2f211b;
      --muted: #7a655b;
      --card: rgba(255, 248, 242, 0.88);
      --shadow: 0 20px 50px rgba(77, 47, 36, 0.12);
      --radius: 28px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: Inter, Arial, sans-serif;
      background:
        radial-gradient(circle at top left, #fff8f1 0%, transparent 28%),
        radial-gradient(circle at bottom right, #f1d7bf 0%, transparent 22%),
        var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    .container {
      width: min(1180px, calc(100% - 40px));
      margin: 0 auto;
    }

    header {
      padding: 24px 0;
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      background: rgba(255,255,255,0.45);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(77, 47, 36, 0.08);
      border-radius: 999px;
      padding: 14px 20px;
      box-shadow: 0 8px 20px rgba(77, 47, 36, 0.05);
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 700;
      font-size: 20px;
      color: var(--brown);
    }

    .logo-mark {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, var(--accent), var(--brown-2));
      color: #fff;
      font-size: 20px;
      box-shadow: 0 10px 22px rgba(107, 68, 52, 0.24);
    }

    .menu {
      display: flex;
      align-items: center;
      gap: 28px;
      color: var(--muted);
      font-size: 15px;
    }

    .menu a:hover {
      color: var(--brown);
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .btn,
    .btn-outline {
      border: none;
      cursor: pointer;
      font-size: 15px;
      font-weight: 600;
      border-radius: 999px;
      transition: 0.25s ease;
    }

    .btn {
      background: linear-gradient(135deg, var(--brown), var(--brown-2));
      color: #fff;
      padding: 14px 22px;
      box-shadow: 0 14px 28px rgba(77, 47, 36, 0.2);
    }

    .btn:hover {
      transform: translateY(-2px);
    }

    .btn-outline {
      background: transparent;
      color: var(--brown);
      border: 1px solid rgba(77, 47, 36, 0.16);
      padding: 13px 20px;
    }

    .hero {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      align-items: center;
      gap: 40px;
      padding: 30px 0 56px;
    }

    .hero-copy h1 {
      font-size: clamp(42px, 7vw, 76px);
      line-height: 0.98;
      letter-spacing: -0.04em;
      color: var(--brown);
      margin-bottom: 22px;
    }

    .hero-copy p {
      max-width: 560px;
      font-size: 18px;
      line-height: 1.7;
      color: var(--muted);
      margin-bottom: 30px;
    }

    .hero-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-bottom: 30px;
    }

    .hero-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 18px;
    }

    .stat {
      background: var(--card);
      border: 1px solid rgba(77,47,36,0.08);
      border-radius: 22px;
      padding: 18px 22px;
      min-width: 150px;
      box-shadow: var(--shadow);
    }

    .stat strong {
      display: block;
      font-size: 24px;
      color: var(--brown);
      margin-bottom: 6px;
    }

    .stat span {
      font-size: 14px;
      color: var(--muted);
    }

    .hero-visual {
      position: relative;
      min-height: 560px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .blob {
      position: absolute;
      width: 520px;
      height: 520px;
      background: linear-gradient(145deg, #f3dbc5, #edc8a2);
      border-radius: 42% 58% 57% 43% / 45% 40% 60% 55%;
      filter: drop-shadow(0 25px 45px rgba(116, 73, 49, 0.18));
      animation: float 8s ease-in-out infinite;
    }

    .cup-card {
      position: relative;
      z-index: 2;
      width: 360px;
      aspect-ratio: 1 / 1.15;
      border-radius: 40px;
      background: linear-gradient(180deg, rgba(255,255,255,0.9), rgba(255,248,242,0.72));
      border: 1px solid rgba(77,47,36,0.08);
      box-shadow: var(--shadow);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      backdrop-filter: blur(12px);
    }

    .cup {
      position: relative;
      width: 190px;
      height: 220px;
      background: linear-gradient(180deg, #fff7ef 0%, #f2e1d4 100%);
      border-radius: 20px 20px 80px 80px;
      box-shadow: inset 0 -16px 20px rgba(124, 81, 58, 0.08);
    }

    .coffee {
      position: absolute;
      top: 18px;
      left: 16px;
      right: 16px;
      height: 72px;
      border-radius: 50px;
      background: radial-gradient(circle at 30% 20%, #8d5e46, #5a362a 70%);
    }

    .foam {
      position: absolute;
      top: 38px;
      left: 45px;
      width: 100px;
      height: 36px;
      border-radius: 50px;
      background: rgba(255, 243, 230, 0.7);
      filter: blur(2px);
    }

    .handle {
      position: absolute;
      right: -34px;
      top: 58px;
      width: 66px;
      height: 92px;
      border: 14px solid #f3e3d5;
      border-left: 14px solid transparent;
      border-radius: 50px;
    }

    .plate {
      position: absolute;
      bottom: 88px;
      width: 300px;
      height: 58px;
      border-radius: 50%;
      background: linear-gradient(180deg, #fff8f2, #ead8ca);
      z-index: -1;
      box-shadow: 0 12px 24px rgba(77,47,36,0.1);
    }

    .floating-card {
      position: absolute;
      z-index: 3;
      background: rgba(255,255,255,0.76);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(77,47,36,0.08);
      box-shadow: var(--shadow);
      border-radius: 22px;
      padding: 16px 18px;
      min-width: 170px;
    }

    .floating-card small {
      display: block;
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 6px;
    }

    .floating-card strong {
      color: var(--brown);
      font-size: 20px;
    }

    .card-top {
      top: 40px;
      left: 0;
    }

    .card-bottom {
      right: 12px;
      bottom: 38px;
    }

    .features {
      padding: 24px 0 80px;
    }

